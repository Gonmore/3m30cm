NODE_ENV=development
PORT=4100
# En producción: https://3m30cm.supernovatel.com (un solo dominio, /api/* va al backend)
WEB_URL=http://localhost:4173
APP_VERSION=local-dev
JWT_ACCESS_SECRET=change-me-super-secret
JWT_ACCESS_EXPIRES_IN=7d
SEED_SUPERADMIN_EMAIL=admin@3m30cm.local
SEED_SUPERADMIN_PASSWORD=Admin123!
RUN_SEED_ON_DEPLOY=0
DATABASE_URL=postgresql://postgres:D3v3%2Fop3R@postgres-local:5432/3m30cm?schema=public
MINIO_ENDPOINT=http://minio-local:9000
MINIO_PUBLIC_BASE_URL=http://localhost:9000
MINIO_BUCKET=jump-assets
MINIO_REGION=us-east-1
MINIO_ACCESS_KEY_ID=minioadmin
MINIO_SECRET_ACCESS_KEY=minioadmin
MINIO_FORCE_PATH_STYLE=true
# La web usa /api relativo por defecto. Solo define VITE_API_BASE_URL si quieres forzar una URL absoluta.
VITE_API_BASE_URL=
EXPO_PUBLIC_API_BASE_URL=http://localhost:4100
# Dentro de Docker, Vite dev-server y nginx del contenedor web hacen proxy /api/* → este target
API_PROXY_TARGET=http://api-3m30cm:4100
# SMTP preparado para recuperación/notificaciones futuras
SMTP_HOST=mail.supernovatel.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=saas@supernovatel.com
SMTP_PASS=change-me
SMTP_FROM=3m30cm <saas@supernovatel.com>
