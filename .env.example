NODE_ENV=development
PORT=4100
# En producción: https://3m30cm.supernovatel.com (un solo dominio, /api/* va al backend)
WEB_URL=http://localhost:4173
APP_VERSION=local-dev
JWT_ACCESS_SECRET=change-me-super-secret
JWT_ACCESS_EXPIRES_IN=7d
SEED_SUPERADMIN_EMAIL=admin@3m30cm.local
SEED_SUPERADMIN_PASSWORD=Admin123!
DATABASE_URL=postgresql://postgres:D3v3%2Fop3R@postgres-local:5432/3m30cm?schema=public
MINIO_ENDPOINT=http://minio-local:9000
MINIO_PUBLIC_BASE_URL=http://localhost:9000
